                Util.Layer.Center($("#vue_app_down_box"),{})
            });
        },
        getOperatingSystem() {
            return ''
            const userAgent = navigator.userAgent.toLowerCase();
            if (userAgent.includes('windows')) {
                this.device = 'windows'
            } else if (userAgent.includes('mac os x')) {
                // 区分Apple芯片和Intel芯片
                this.apple_silicon = navigator.platform !== 'MacIntel'
                this.device = 'macos'
            } else if (userAgent.includes('linux')) {
                this.device = 'linux'
            }
            return '';
        },
        startDownload(downloadType) {
            var vm = this;
            $.ajax({
                url: '//appversion.115.com/1/web/1.0/api/getOneVerson',
                method: 'GET',
                dataType: 'json',
                data: {
                    app_os: this.downInfo[downloadType].app_os,
                },
                xhrFields: {
                    withCredentials: true,
                },
                success: function (res) {
                    if (res.state) {
                        vm.downloadByUrl(_.get(res, 'data.version_url'));
                    } else {
                        $.alertTip(res.message);
                    }
                },
            })
        },
        downloadByUrl(url) {
            if (!url) return false;
            var eleLink = document.createElement('a');
            eleLink.href = url.replace(/^http[s]?:/ig, location.protocol);
            eleLink.target = '_blank';
            eleLink.style.display = 'none';
            // 触发点击
            document.body.appendChild(eleLink);
            eleLink.click();
            // 然后移除
            document.body.removeChild(eleLink);
        },
        gotoUrl(url) {
            window.open(url)
        }
