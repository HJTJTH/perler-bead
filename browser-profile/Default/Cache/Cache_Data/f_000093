                            login_box.find('[rel=list_other_login]').show();
                            break;
                    }
                };
                thirdPartInit(nav)
                login_box.find('[lgb-nav]').show();
                login_box.find('[lgb-nav]').parent().next('i:eq(0)').show();
                el.hide();
                $('[lg_rel]').hide();
                $('[lg_rel="'+nav+'"]').show();
