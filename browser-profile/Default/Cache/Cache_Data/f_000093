            login_box.find('[lgb-nav]').click(function(){
                var el = $(this), nav = $(this).attr('lgb-nav');
                if(nav != 'qrcode' && isMobile) {
                    login_box.find('[lgb-nav=qrcode]').click();
                    return false;
                }
                function thirdPartInit(nav) {
                    switch (nav) {
                        case 'noqcode':
                        case 'password_recorded_login':
                            login_box.find('[rel=login_footer]').css('bottom','0');
                            login_box.find('[rel=list_other_login]').hide();
