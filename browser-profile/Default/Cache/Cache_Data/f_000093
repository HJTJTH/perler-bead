                    oofUtil.loginApi.passwordRecordedLogin.rememberPasswordTipsInit()
                }
                $('#js_login_qrcode_tip_d').show();
                $('#js_login_qrcode_tip_s').hide();

                load_QCODE && clearTimeout(load_QCODE);
                load_ISSTART = false;
                if(nav == 'qrcode') {
                    load_ISSTART = true;
                    // oofUtil.loginApi.qrcode.load();
                    loginWk.refresh();
                }

                return false;
            });
            login_box.find('[thirdpart]').click(function () {
                var type = $(this).attr('thirdpart');
                if(type=='sms'){
                    showLoginBox();
                }else{
                    oofUtil.loginApi.thirdPartLogin({
                        type: type,
                        suc_url: vm.goto
                    })
                }

                return false;
            });

            oofUtil.loginApi.passwordRecordedLogin.init({
                $warp:  login_box.find('[lg_rel="password_recorded_login"]'),
                unbindCallback: function(){
                    login_box.find('[lgb-nav="qrcode"]').trigger('click');
                },
