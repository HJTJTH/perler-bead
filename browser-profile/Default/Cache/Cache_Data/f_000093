                    moreCountryBox.find('[country].focus').removeClass('focus');
                    countryTab.attr('country', val);
                    if(val==''){
                        countryTab.find('.gc').html('账号');
                    }else{
                        countryTab.find('.gc').html(btn.html());
                    }

                    if (val == '') {
                        account.isMobile = false;
                        if (account.val()) {
                            account.val('');
                        }
                        mobileSea.Disabled();
                        defaultSea.Enabled();

                        $('#js-account-box').addClass('lr-number')
                        codeSpan.hide();
                    }
                    else {
                        btn.addClass('focus');
                        account.isMobile = true;
                        if (account.val()) {
                            account.val('');
                        }

                        $('#js-account-box').removeClass('lr-number')
                        //account.val(code);
                        codeSpan.html('+' + code).show();
                        mobileSea.Enabled();
                        defaultSea.Disabled();

                        $('#js-passwd').val('');
                    }
                    account.focus();
                    //focusEnd(account[0]);
                }


                var setTag = function(tag){
                    var link = moreCountryBox.find('[tag="'+tag+'"]');
                    moreCountryBox.find('.current').removeClass('current');
                    link.addClass('current');
                    var conTag = moreCountryBox.find('[contag="'+tag+'"]');
                    //moreCountryBox.find('[contag]').hide();
                    if(!conTag.length){
                        oofUtil.loginApi.getCountry(tag, function(json){
                            if(json.state){
                                var conBox = $('<div class="pop-region-container" contag="'+tag+'" style="display:none;position:relative;"></div>');
                                for(var k in json.data){
                                    var dataItem = json.data[k];
                                    if(dataItem && dataItem.length){
                                        var html = [];
                                        // html.push('<dl><dt>'+k+'</dt><dd><ul>');
                                        html.push('<ul>');
                                        for(var i = 0, len = dataItem.length; i < len; i++){
                                            var item = dataItem[i];
                                            html.push('<li><a href="javascript:;" country="'+item.ios2+'" code="'+item.code+'">'+item.name+'</a></li>');
                                        }
                                        html.push('</ul>');
                                        conBox.append(html.join(''));
                                    }
                                }
                                moreCountryBox.find('[rel=pop_bottom]').before(conBox);

                                //moreCountryBox.append(conBox);
                                moreCountryBox.find('[contag]').hide();

                                conBox.show();
                            }
                        });
