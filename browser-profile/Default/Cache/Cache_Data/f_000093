                        xhrFields: {withCredentials: true},

                        success: function (json) {
                            if (json.state) {
                                vm.userInfo = json.data || null;
                                vm.loadYunInfo()
                            }
                        }
                    });
                } else {
                    var $item = login_box.find('[lgb-nav=' + lnav + ']');
                    if (!$item.length) {
                        $item = login_box.find('[lgb-nav="qrcode"]');
                    }
                    $item.click();
                }
                var xmlHttp = window.XMLHttpRequest && new XMLHttpRequest(); //浏览器需要升级
                if (!window.XMLHttpRequest || !('withCredentials' in xmlHttp)) {
                    $('[lg_rel]').hide();
                    $('[lg_rel="upgrade"]').show();
                }
                /*if(oofUtil.loginApi.canAccountLogin()) {
                    login_box.find('[lgb-nav="login"]').click();
                    return;
                }
                login_box.find('[lgb-nav="download"]').click();*/

            });
        },
        loadYunInfo() {
            if (this.pageType != '115office' || !window.CUR_USER_ID) return;
            var vm = this;
            var yun_url = '//yun.115.com';

            $.ajax({
                url: '//yun.115.com/api/1.0/web/1.0/1/portal/heartbeat',
                dataType: 'json',
                type: 'post',
                data: {a:'init'},
                xhrFields: {withCredentials: true},
                timeout: 5000,//5秒没有返回就超时掉
                complete: function () {

                },
                success: function (json) {

                },
                error: function (e) {

                }
            });

            $.ajax({
                url: yun_url + '/api/1.0/web/1.0/login/login_info',
                type: 'POST',
                dataType: 'json',
                xhrFields: {withCredentials: true},
                success: (r) => {
                    if (r.state) {
                        this.yunGroupStatus.loaded = true;
                        var data = r.data || {};
                        if (!data.groups.length) {
                            this.yunGroupStatus.noGroup = true;
                            if (data.invites.length) {
                                this.yunGroupStatus.hasInvite = true;
                                this.yunGroupStatus.invitesInfo = data.invites[0] || {};
                            } else {
                                this.yunGroupStatus.hasInvite = false;
                                if (!this.yunGroupStatus.imloaded) {
                                    window.USER_FACE = {};
                                    this.yunGroupStatus.imloaded = true;
                                    //window.im = {};
                                    oofUtil.loadJs('//cdnassets.115.com/??oofUtil/subscribe.js,im/6.1/yun-baseData.js,im/6.1/connect.js,im/6.1/im-for-min.js?v=', function () {
                                        im.connect.init(function () {
                                            oofUtil.subscribe.on('OOFPlusOriginalMessage_701007', function () {
                                                vm.loadYunInfo();
                                            })
                                        }, undefined, 1);
                                    });
                                }
                            }
                        } else {
                            this.yunGroupStatus.noGroup = false;
                        }
                    } else {
                        $.alertTip(r.message || '网络异常请刷新重试');
                    }
                },
            });
        },
        joinGroup(type) {
            var vm = this;
            var yun_url = '//yun.115.com';
            vm.yunGroupStatus.posting = true;
            $.ajax({
                url: yun_url + '/api/1.0/web/1.0/' + vm.yunGroupStatus.invitesInfo['gid'] + '/group/deal_invite',
                type: 'POST',
                dataType: 'json',
                data: {invite_id: vm.yunGroupStatus.invitesInfo['invite_id'], action: type},
                xhrFields: {withCredentials: true},
                success: function (JSON) {
                    vm.yunGroupStatus.posting = false;
                    if (JSON.state) {
                        if (type == 'refuse') {
                            $.successTip('拒绝成功' || JSON.message || '网络异常请刷新重试');
                            setTimeout(function () {
                                window.location.reload();
                            }, 2000);
                        } else {
                            window.location.href = yun_url + '/' + vm.yunGroupStatus.invitesInfo['gid'];
                        }
                    } else {
                        $.alertTip(JSON.message || '网络异常请刷新重试');
                    }
                },
                error: function () {
                    vm.yunGroupStatus.posting = false;
                }
            })
        },
    }
}
</script>


